# Ollama Configuration
# Optional: Specify Ollama base URL (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: Specify Ollama model (default: llama3.2:latest)
# Popular models: qwen2.5:7b, llama3.2, mistral, gemma2
# OLLAMA_MODEL=llama3.2:latest

# Optional: API timeout in seconds (default: 600)
# Increase if running on CPU or with large logs
# OLLAMA_TIMEOUT=900

# Optional: Server port (default: 8080)
# PORT=8080
